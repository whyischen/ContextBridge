# Include core package and all subpackages
recursive-include core *.py

# Include version file explicitly
include core/__version__.py

# Include main entry points
include cbridge.py
include __main__.py

# Include configuration and documentation
include README.md
include README_zh-CN.md
include LICENSE
include requirements.txt
include pyproject.toml

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.so
global-exclude *.dylib
